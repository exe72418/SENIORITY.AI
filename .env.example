# --- SENIORITY.AI CONFIGURATION ---

# Choose your AI Provider: gemini, openai, or claude
AI_PROVIDER=gemini

# Your API Key (REQUIRED)
# Get Gemini key at: https://aistudio.google.com/app/apikey
AI_API_KEY=your_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_classic_token_here
GITHUB_USERNAME=your_username

# Workspace settings
LOCAL_WORKSPACE_PATH=./workspace
DEBUG=true
